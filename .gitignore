# Create the .gitignore from Nushell
"# Cargo build artifacts
target/
debug/

# Rust formatter backups
**/*.rs.bk

# Windows MSVC debug symbols
*.pdb

# Cargo mutation testing output
**/mutants.out*/

# IDE
.idea/
.vscode/
*.iml

# Environment / secrets
.env
.env.local

# OS
.DS_Store
Thumbs.db
desktop.ini

# mrar test data (do not commit real bill images)

tests/receipts/
tests/fixtures/*.jpg
tests/fixtures/*.jpeg
tests/fixtures/*.png
tests/fixtures/*.tiff
tests/fixtures/*.tif
tests/fixtures/*.webp
